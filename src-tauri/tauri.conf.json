{
  "productName": "SwiftSSH",
  "version": "0.1.0",
  "identifier": "com.swiftssh.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SwiftSSH",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "acceptFirstMouse": true,
        "dragDropEnabled": false,
        "trafficLightPosition": {
          "x": 16,
          "y": 20
        }
      },
      {
        "label": "settings",
        "title": "Settings",
        "width": 800,
        "height": 550,
        "resizable": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "visible": false,
        "trafficLightPosition": {
          "x": 16,
          "y": 20
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
